{
  "name": "macintosh.js",
  "productName": "macintosh.js",
  "version": "1.2.0",
  "description": "Macintosh's System 8 in an Electron app. I'm sorry.",
  "main": "./dist/src/main/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "prettier --check \"src/{main,renderer}/**/*.{ts,js,css}\" && npm run check-links",
    "fix": "prettier --write \"src/{main,renderer}/**/*.{ts,js,css}\"",
    "tsc": "tsc -p tsconfig.json --noEmit",
    "check-links": "node tools/check-links.js",
    "postinstall": "patch-package"
  },
  "keywords": [],
  "author": {
    "name": "Felix Rieseberg",
    "email": "felix@felixrieseberg.com"
  },
  "license": "MIT",
  "config": {
    "forge": "./forge.config.js"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "update-electron-app": "^3.1.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.1",
    "@electron-forge/maker-deb": "7.11.1",
    "@electron-forge/maker-rpm": "7.11.1",
    "@electron-forge/maker-squirrel": "7.11.1",
    "@electron-forge/maker-zip": "7.11.1",
    "@electron-forge/publisher-github": "7.11.1",
    "@types/node": "^22.19.17",
    "dotenv": "^17.3.1",
    "electron": "41.2.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^7.3.1"
  }
}
